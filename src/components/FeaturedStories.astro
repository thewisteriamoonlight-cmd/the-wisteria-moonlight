---
/**
 * FeaturedStories.astro
 * ---------------------------------------------------------
 * Editorial "Featured Stories" section for The Wisteria Moonlight.
 *
 * A pure composition component — it does not restyle anything.
 * It renders a semantic <section> with:
 *
 *   • a SectionHeading (eyebrow + title + optional description)
 *   • a responsive grid of StoryCard components
 *
 * Responsibilities owned by this component:
 *   - semantic section element
 *   - section-level spacing (vertical rhythm)
 *   - responsive grid layout (1 → 2 → 3 columns)
 *
 * Responsibilities NOT owned by this component:
 *   - card typography, hover, image treatment, focus ring
 *     (those live inside StoryCard)
 *   - heading typography and alignment
 *     (those live inside SectionHeading)
 */

import SectionHeading from "./SectionHeading.astro";
import StoryCard from "./StoryCard.astro";

import type { Story } from "../lib/articles";

interface Props {
  eyebrow?: string;
  title: string;
  description?: string;

  stories: Story[];
}

const {
  eyebrow,
  title,
  description,
  stories,
} = Astro.props;
---

<section class="featured-stories">
  <div class="featured-stories__container">

    <SectionHeading
      eyebrow={eyebrow}
      title={title}
      description={description}
      level="h2"
      align="center"
    />

    <ul class="featured-stories__grid" role="list">
      {stories.map((story) => (
        <li class="featured-stories__item">
          <StoryCard story={story} />
        </li>
      ))}
    </ul>

  </div>
</section>

<style>
  /* -----------------------------------------------------------------------
   * Section shell
   * Owns vertical rhythm between adjacent page sections. No background,
   * no borders — the parent page decides the surface. Spacing scales
   * up at desktop for a more generous editorial rhythm.
   * ----------------------------------------------------------------------- */
  .featured-stories {
    padding-block: var(--spacing-section);
  }

  @media (min-width: 1024px) {
    .featured-stories {
      padding-block: var(--spacing-section-lg);
    }
  }

  /* -----------------------------------------------------------------------
   * Container
   * Caps width to the standard content measure and applies a
   * responsive page gutter. Stacks the section heading and the
   * grid with generous space between them.
   * ----------------------------------------------------------------------- */
  .featured-stories__container {
    width: 100%;
    max-width: var(--container-content);
    margin-inline: auto;
    padding-inline: var(--spacing-gutter);

    display: flex;
    flex-direction: column;
    gap: calc(var(--spacing) * 12);
  }

  @media (min-width: 1024px) {
    .featured-stories__container {
      padding-inline: var(--spacing-gutter-lg);
      gap: calc(var(--spacing) * 16);
    }
  }

  /* -----------------------------------------------------------------------
   * Grid
   * Mobile-first single column. Expands to two columns at tablet
   * and three columns at desktop. CSS Grid only — no masonry,
   * no carousel, no JavaScript.
   * ----------------------------------------------------------------------- */
  .featured-stories__grid {
    list-style: none;
    margin: 0;
    padding: 0;

    display: grid;
    grid-template-columns: 1fr;
    gap: calc(var(--spacing) * 10);
  }

  @media (min-width: 640px) {
    .featured-stories__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1024px) {
    .featured-stories__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: calc(var(--spacing) * 12);
    }
  }

  /* -----------------------------------------------------------------------
   * Grid item
   * Neutral list-item wrapper — no visual styling. Ensures each
   * StoryCard stretches to fill its cell so cards align cleanly
   * across a row regardless of content length.
   * ----------------------------------------------------------------------- */
  .featured-stories__item {
    margin: 0;
    display: flex;
  }
</style>
