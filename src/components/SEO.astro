---
/**
 * ============================================================================
 * SEO.astro
 * ============================================================================
 *
 * Reusable SEO metadata component for The Wisteria Moonlight.
 *
 * Responsibilities:
 *   - Render <meta name="description">
 *   - Render <link rel="canonical">
 *   - Render Open Graph tags
 *   - Render Twitter Card tags
 *
 * NON-Responsibilities (intentional):
 *   - Does NOT render <title> — BaseLayout continues to own the document title.
 *   - No layout
 *   - No styling
 *   - No page logic
 *   - No article logic
 *   - No category logic
 *   - No JSON-LD or schema (BaseLayout owns sitewide structured data)
 *
 * Usage:
 *   BaseLayout integrates this component once for every page and forwards
 *   page-specific metadata props from route templates. Pages should pass
 *   title, description, canonical, image, and type through BaseLayout rather
 *   than rendering SEO.astro directly.
 * ============================================================================
 */

// ----------------------------------------------------------------------------
// Props
// ----------------------------------------------------------------------------
interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  type?: "website" | "article";
}

import { SITE, absoluteUrl } from "../data/siteMetadata";

const DEFAULT_TYPE: "website" | "article" = "website";

const {
  title,
  description,
  canonical,
  image,
  type = DEFAULT_TYPE,
} = Astro.props;

// ----------------------------------------------------------------------------
// Derived values
// ----------------------------------------------------------------------------
// Resolve the canonical URL:
//   - If a canonical is explicitly passed, use it.
//   - Otherwise, fall back to the current request pathname.
const canonicalURL = canonical
  ? absoluteUrl(canonical)
  : absoluteUrl(Astro.url.pathname);

// Resolve the OG/Twitter image to an absolute URL when possible.
//   - Only compute this if an image was actually provided.
//   - If `image` is already absolute (http/https), leave it alone.
//   - If it is a relative path (e.g. "/og/hero.jpg"), resolve against Astro.site.
//   - If Astro.site is not configured, fall back to the raw value.
let resolvedImage: string | undefined;
if (image) {
  const isAbsolute = /^https?:\/\//i.test(image);
  resolvedImage = isAbsolute
    ? image
    : absoluteUrl(image);
}
---

<!-- ==========================================================================
     Primary meta
     (title is intentionally owned by BaseLayout, not this component)
     ========================================================================== -->
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />

<!-- ==========================================================================
     Open Graph
     ========================================================================== -->
<meta property="og:site_name" content={SITE.name} />
<meta property="og:locale" content={SITE.locale} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
{resolvedImage && <meta property="og:image" content={resolvedImage} />}

<!-- ==========================================================================
     Twitter
     ========================================================================== -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
{resolvedImage && <meta name="twitter:image" content={resolvedImage} />}
