---
/**
 * Newsletter.astro
 * ---------------------------------------------------------
 * Editorial newsletter signup section for The Wisteria Moonlight.
 *
 * Composes a centered SectionHeading with a quiet, accessible
 * email signup form. Presentational only — no JavaScript, no
 * backend wiring. Submission handling is intentionally deferred
 * to the ESP integration layer described in TAD Section 25.
 *
 * Responsibilities owned by this component:
 *   - semantic <section>
 *   - section-level spacing (vertical rhythm)
 *   - constrained centered container
 *   - form layout, input and button styling
 *
 * Responsibilities NOT owned by this component:
 *   - heading typography and alignment (SectionHeading)
 *   - form submission behavior / ESP integration
 */

import SectionHeading from "./SectionHeading.astro";

interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  placeholder?: string;
  buttonText?: string;
}

const {
  eyebrow,
  title,
  description,
  placeholder = "Enter your email",
  buttonText = "Subscribe",
} = Astro.props;
---

<section class="newsletter">
  <div class="newsletter__container">

    <SectionHeading
      eyebrow={eyebrow}
      title={title}
      description={description}
      level="h2"
      align="center"
    />

  <form
  class="newsletter__form"
  method="post"
>

      <label class="sr-only" for="newsletter-email">
        Email address
      </label>

      <input
        class="newsletter__input"
        id="newsletter-email"
        type="email"
        placeholder={placeholder}
        autocomplete="email"
        required
      />

      <button class="newsletter__button" type="submit">
        {buttonText}
      </button>

    </form>

  </div>
</section>

<style>
  /* -----------------------------------------------------------------------
   * Section shell
   * Owns vertical rhythm between adjacent page sections. No background,
   * no borders — the parent page decides the surface. Spacing scales
   * up at desktop for a more generous editorial rhythm.
   * ----------------------------------------------------------------------- */
  .newsletter {
    padding-block: var(--spacing-section);
  }

  @media (min-width: 1024px) {
    .newsletter {
      padding-block: var(--spacing-section-lg);
    }
  }

  /* -----------------------------------------------------------------------
   * Container
   * Narrow, centered column — the newsletter is a focused conversion
   * moment, not a wide layout region. Stacks the heading and the
   * form with generous space between them.
   * ----------------------------------------------------------------------- */
  .newsletter__container {
    width: 100%;
    max-width: 42rem;
    margin-inline: auto;
    padding-inline: var(--spacing-gutter);

    display: flex;
    flex-direction: column;
    gap: calc(var(--spacing) * 10);
  }

  /* -----------------------------------------------------------------------
   * Screen-reader-only label
   * The visible placeholder handles the sighted user; the label is
   * preserved for assistive technology per accessibility standards.
   * ----------------------------------------------------------------------- */
  .sr-only {
    position: absolute !important;
    width: 1px !important;
    height: 1px !important;
    padding: 0 !important;
    margin: -1px !important;
    overflow: hidden !important;
    clip: rect(0, 0, 0, 0) !important;
    white-space: nowrap !important;
    border: 0 !important;
  }

  /* -----------------------------------------------------------------------
   * Form
   * Mobile-first vertical stack — the input sits above the button
   * for comfortable tap targets on small screens. At tablet and
   * above, the two collapse into a single horizontal row.
   * ----------------------------------------------------------------------- */
  .newsletter__form {
    display: flex;
    flex-direction: column;
    gap: calc(var(--spacing) * 4);
  }

  @media (min-width: 768px) {
    .newsletter__form {
      flex-direction: row;
      align-items: stretch;
    }
  }

  /* -----------------------------------------------------------------------
   * Input
   * Body serif for the value, muted placeholder, quiet border that
   * shifts to the accent on focus. Grows to fill the row on desktop.
   * ----------------------------------------------------------------------- */
  .newsletter__input {
    flex: 1;
    font-family: var(--font-body);
    font-size: var(--text-body);
    line-height: var(--text-body--line-height);
    color: var(--color-text);
    background-color: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-soft);
    padding: calc(var(--spacing) * 3) calc(var(--spacing) * 4);
    transition: border-color var(--duration-base) var(--ease-quiet),
                box-shadow var(--duration-base) var(--ease-quiet);
  }

  .newsletter__input::placeholder {
    color: var(--color-text-subtle);
  }

  .newsletter__input:focus-visible {
  outline: 2px solid var(--color-accent);
  outline-offset: 2px;
  border-color: var(--color-accent);
}

  /* -----------------------------------------------------------------------
   * Button
   * Quiet editorial button — UI font, uppercase, widest tracking.
   * Wisteria fill by default, deepening on hover/focus. Uses only
   * the existing duration and easing tokens.
   * ----------------------------------------------------------------------- */
  .newsletter__button {
    font-family: var(--font-ui);
    font-size: var(--text-label);
    line-height: 1;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-white);
    background-color: var(--color-accent);
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-soft);
    padding: calc(var(--spacing) * 4) calc(var(--spacing) * 6);
    cursor: pointer;
    transition: background-color var(--duration-base) var(--ease-quiet),
                border-color var(--duration-base) var(--ease-quiet),
                color var(--duration-base) var(--ease-quiet);
  }

  .newsletter__button:hover {
    background-color: var(--color-wisteria-deep);
    border-color: var(--color-wisteria-deep);
  }

  .newsletter__button:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
</style>