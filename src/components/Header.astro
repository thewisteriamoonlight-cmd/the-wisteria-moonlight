---
/**
 * Header.astro
 * -----------------------------------------------------------------------------
 * The Wisteria Moonlight — Global site header.
 *
 * Sticky, editorial header composed of:
 *   • Brand wordmark on the left (Playfair Display)
 *   • <Navigation /> on the right, desktop only
 *   • Hamburger button on the right, mobile only (no menu wired up yet)
 *
 * The primary navigation now lives in its own reusable component
 * (src/components/Navigation.astro). This file is responsible only for the
 * header shell: layout, sticky behavior, brand, and mobile toggle.
 *
 * No JavaScript, no external libraries. All styling flows from design tokens
 * defined in src/styles/global.css.
 * -----------------------------------------------------------------------------
 */

import Navigation from "./Navigation.astro";
---

<header class="site-header" role="banner">
  <div class="site-header__inner site-container">

    <!-- Brand -->
    <a class="site-header__brand" href="/" aria-label="The Wisteria Moonlight — home">
      The Wisteria Moonlight
    </a>

    <!-- Desktop navigation (visibility controlled by header breakpoint) -->
    <div class="site-header__nav">
      <Navigation />
    </div>

    <!-- Mobile hamburger (visual only — menu not yet implemented) -->
    <button
      type="button"
      class="site-header__toggle"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="site-nav"
    >
      <span class="site-header__toggle-bar" aria-hidden="true"></span>
      <span class="site-header__toggle-bar" aria-hidden="true"></span>
      <span class="site-header__toggle-bar" aria-hidden="true"></span>
    </button>

  </div>
</header>

<style>
  /* -------------------------------------------------------------------------
     Site header shell
     ------------------------------------------------------------------------- */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background-color: var(--color-surface);
    border-bottom: 1px solid var(--color-border-soft);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    min-height: 4.5rem;
  }

  /* -------------------------------------------------------------------------
     Brand wordmark
     ------------------------------------------------------------------------- */
  .site-header__brand {
    font-family: var(--font-display);
    font-size: 1.5rem;
    line-height: 1;
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
    text-decoration: none;
    white-space: nowrap;
    transition: color var(--duration-base) var(--ease-quiet);
  }
  .site-header__brand:hover {
    color: var(--color-accent);
  }

  /* -------------------------------------------------------------------------
     Desktop navigation container
     Hidden on mobile; revealed at the desktop breakpoint. The <Navigation />
     component owns its own internal styling.
     ------------------------------------------------------------------------- */
  .site-header__nav {
    display: none;
  }

  /* -------------------------------------------------------------------------
     Mobile hamburger
     ------------------------------------------------------------------------- */
  .site-header__toggle {
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 2.5rem;
    height: 2.5rem;
    padding: 0.5rem;
    background: transparent;
    border: 0;
    border-radius: var(--radius-soft);
    cursor: pointer;
    color: var(--color-text);
    transition: color var(--duration-base) var(--ease-quiet);
  }
  .site-header__toggle:hover,
  .site-header__toggle:focus-visible {
    color: var(--color-accent);
  }

  .site-header__toggle-bar {
    display: block;
    width: 100%;
    height: 1px;
    background-color: currentColor;
  }

  /* -------------------------------------------------------------------------
     Breakpoint: desktop
     ------------------------------------------------------------------------- */
  @media (min-width: 768px) {
    .site-header__inner {
      min-height: 5.5rem;
    }
    .site-header__brand {
      font-size: 1.75rem;
    }
    .site-header__nav {
      display: block;
    }
    .site-header__toggle {
      display: none;
    }
  }
</style>