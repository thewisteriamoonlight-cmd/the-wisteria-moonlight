---
/**
 * CategoryCard.astro
 * ---------------------------------------------------------
 * Reusable editorial category card for The Wisteria Moonlight.
 *
 * Represents a category (not an individual article) — used in
 * the homepage category browser, category index pages, and
 * anywhere a curated topic entry is presented.
 *
 * Fully presentational. The parent owns grid, columns,
 * spacing, and width. This component controls only its own
 * presentation and interaction.
 */

import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  title: string;
  href: string;

  image: ImageMetadata;
  imageAlt: string;

  description?: string;
}

const {
  title,
  href,
  image,
  imageAlt,
  description,
} = Astro.props;
---

<article class="category-card">
  <a href={href} class="category-card__link">
    <figure class="category-card__media">
      <Image
        class="category-card__image"
        src={image}
        alt={imageAlt}
      />
    </figure>

    <div class="category-card__content">
      <h3 class="category-card__title">
        {title}
      </h3>

      {description && (
        <p class="category-card__description">
          {description}
        </p>
      )}
    </div>
  </a>
</article>

<style>
  /* -----------------------------------------------------------------------
   * Root
   * The card is a self-contained block. It does not control its own
   * width — the parent grid decides. Height stretches to fill the row
   * so grids of cards align cleanly.
   * ----------------------------------------------------------------------- */
  .category-card {
    height: 100%;
    margin: 0;
  }

  /* -----------------------------------------------------------------------
   * Link
   * The entire card is a single anchor. Uses a flex column so the
   * media sits above the content and the content region can grow.
   * Underline is removed — the title carries the link affordance.
   * ----------------------------------------------------------------------- */
  .category-card__link {
    display: flex;
    flex-direction: column;
    width: 100%;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  /* -----------------------------------------------------------------------
   * Focus
   * Quiet, accessible keyboard focus ring using the accent color.
   * Matches the StoryCard focus treatment so cards share a single
   * interaction language across the design system.
   * ----------------------------------------------------------------------- */
  .category-card__link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
  }

  /* -----------------------------------------------------------------------
   * Media
   * Square 1:1 aspect ratio, image fills the frame via object-fit.
   * Overflow hidden so the hover zoom stays clipped to the card.
   * Print-inspired square edges — no rounding.
   * ----------------------------------------------------------------------- */
  .category-card__media {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    margin: 0;
    overflow: hidden;
  }

  .category-card__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-quiet);
  }

  /* -----------------------------------------------------------------------
   * Hover — image
   * Subtle zoom on card hover/focus. Editorial, not dramatic.
   * Ownership sits on the card itself so the interaction is a
   * property of the component, not of its inner anchor. Matches
   * the StoryCard interaction language.
   * ----------------------------------------------------------------------- */
  .category-card:is(:hover, :focus-within) .category-card__image {
    transform: scale(1.03);
  }

  /* -----------------------------------------------------------------------
   * Content
   * Text region below the image. Column layout with generous
   * spacing between title and description. flex: 1 so cards of
   * varying content length still stretch evenly inside a grid row.
   * ----------------------------------------------------------------------- */
  .category-card__content {
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: calc(var(--spacing) * 3);
    padding-block: calc(var(--spacing) * 5);
  }

  /* -----------------------------------------------------------------------
   * Title
   * Primary heading of the card and the strongest visual element.
   * Playfair Display at h3 scale with balanced wrapping for elegant
   * multi-line titles. Color shifts to accent on card hover.
   * ----------------------------------------------------------------------- */
  .category-card__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--text-h3);
    line-height: var(--text-h3--line-height);
    letter-spacing: var(--tracking-tight);
    font-weight: 500;
    color: var(--color-text);
    text-wrap: balance;
    transition: color var(--duration-base) var(--ease-quiet);
  }

  /* -----------------------------------------------------------------------
   * Hover — title
   * Title color shifts to the accent on card hover/focus.
   * Ownership sits on the card itself, matching StoryCard.
   * ----------------------------------------------------------------------- */
  .category-card:is(:hover, :focus-within) .category-card__title {
    color: var(--color-accent);
  }

  /* -----------------------------------------------------------------------
   * Description
   * Optional supporting paragraph. Body serif, muted color,
   * comfortable reading rhythm. Wraps naturally — no line clamp,
   * since category descriptions are short by editorial convention.
   * ----------------------------------------------------------------------- */
  .category-card__description {
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--text-body);
    line-height: var(--text-body--line-height);
    color: var(--color-text-muted);
    text-wrap: pretty;
  }
</style>