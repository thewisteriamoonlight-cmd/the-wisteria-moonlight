---
/**
 * Hero.astro
 * -----------------------------------------------------------------------------
 * The Wisteria Moonlight — Editorial homepage hero.
 *
 * A calm first viewport with local editorial photography and text layered
 * directly over the image.
 *
 * Content is fixed for the homepage; presentational only.
 * -----------------------------------------------------------------------------
 */
import { Image } from "astro:assets";
import heroImage from "../assets/images/posts/cozy-living.jpg";
---

<section class="hero" aria-labelledby="hero-headline">
  <Image
    class="hero__image"
    src={heroImage}
    alt=""
    aria-hidden="true"
    loading="eager"
  />

  <div class="hero__inner site-container">

    <p class="hero__eyebrow">
      <span class="hero__eyebrow-mark" aria-hidden="true"></span>
      <span class="hero__eyebrow-text">Editorial Lifestyle Journal</span>
    </p>

    <h1 id="hero-headline" class="hero__headline">
      The Wisteria Moonlight
    </h1>

    <p class="hero__lede">
      Dreamy finds for softer days: beautiful homes, quiet routines,
      meaningful gifts, timeless style, and everyday moments worth savoring.
    </p>

    <div class="hero__actions">
      <a class="hero__cta" href="#latest-posts">
        Explore the Journal
      </a>
    </div>

  </div>
</section>

<style>
  /* -------------------------------------------------------------------------
     Hero shell
     A generous, quiet stage. Vertical rhythm is driven by section tokens
     from the design system so the hero breathes consistently with the
     rest of the page.
     ------------------------------------------------------------------------- */
  .hero {
    position: relative;
    min-height: clamp(34rem, 76vh, 46rem);
    isolation: isolate;
    overflow: hidden;
    background-color: var(--color-surface-inverse);
    padding-block: var(--spacing-section);
  }

  .hero::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background-color: color-mix(in oklab, var(--color-ink) 38%, transparent);
  }

  .hero__image {
    position: absolute;
    inset: 0;
    z-index: -2;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__inner {
    min-height: calc(clamp(34rem, 76vh, 46rem) - (var(--spacing-section) * 2));
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    gap: 1.5rem;
    max-width: var(--container-reading);
  }

  /* -------------------------------------------------------------------------
     Eyebrow
     Small-caps UI label with a short accent rule — an editorial gesture
     that anchors the headline without adding visual noise.
     ------------------------------------------------------------------------- */
  .hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    margin: 0;
    font-family: var(--font-ui);
    font-size: var(--text-label);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-cream);
  }

  .hero__eyebrow-mark {
    display: inline-block;
    width: 2rem;
    height: 1px;
    background-color: var(--color-rose-soft);
  }

  .hero__eyebrow-text {
    display: inline-block;
  }

  /* -------------------------------------------------------------------------
     Headline
     Playfair Display at editorial hero scale. Balanced wrapping keeps
     the shape of the line calm on every viewport.
     ------------------------------------------------------------------------- */
  .hero__headline {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw + 1rem, 4.5rem);
    line-height: 1.05;
    letter-spacing: var(--tracking-tight);
    color: var(--color-cream);
    margin: 0;
    text-wrap: balance;
    max-width: 20ch;
  }

  /* -------------------------------------------------------------------------
     Lede / supporting copy
     Slightly larger than body copy, softer in color, constrained to a
     comfortable reading measure.
     ------------------------------------------------------------------------- */
  .hero__lede {
    font-family: var(--font-body);
    font-size: var(--text-h5);
    line-height: 1.7;
    color: var(--color-cream);
    margin: 0;
    max-width: 44ch;
    text-wrap: pretty;
  }

  /* -------------------------------------------------------------------------
     Actions
     A single pill CTA with a quiet ink-to-cream hover — no shadow, no
     glow, no motion beyond a color transition.
     ------------------------------------------------------------------------- */
  .hero__actions {
    margin-top: 1rem;
  }

  .hero__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-family: var(--font-ui);
    font-size: var(--text-label);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-ink);
    background-color: var(--color-cream);
    border: 1px solid var(--color-cream);
    border-radius: var(--radius-pill);
    padding: 0.9rem 1.9rem;
    text-decoration: none;
    transition: background-color var(--duration-base) var(--ease-quiet),
                color var(--duration-base) var(--ease-quiet),
                border-color var(--duration-base) var(--ease-quiet);
  }

  .hero__cta:hover,
  .hero__cta:focus-visible {
    background-color: transparent;
    color: var(--color-cream);
    text-decoration: none;
  }

  /* -------------------------------------------------------------------------
     Breakpoint: desktop
     More generous vertical stage on larger screens.
     ------------------------------------------------------------------------- */
  @media (min-width: 768px) {
    .hero {
      padding-block: var(--spacing-section-lg);
    }
    .hero__inner {
      min-height: calc(clamp(34rem, 76vh, 46rem) - (var(--spacing-section-lg) * 2));
    }
    .hero__inner {
      gap: 2rem;
    }
  }

  @media (min-width: 1024px) {
    .hero {
      padding-block: var(--spacing-section-xl);
    }
  }
</style>
