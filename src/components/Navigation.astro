---
/**
 * Navigation.astro
 * -----------------------------------------------------------------------------
 * The Wisteria Moonlight — Primary desktop navigation.
 *
 * Reusable, presentational navigation used inside the site header and mobile
 * menu. Renders links from categoryMetadata so navigation stays aligned with
 * the category pages generated at build time.
 * -----------------------------------------------------------------------------
 */

import categoryMetadata from "../data/categoryMetadata";

interface Props {
  ariaLabel?: string;
  id?: string;
}

const { ariaLabel = "Primary", id } = Astro.props;

const navLinks = [
  { label: "Home", href: "/" },
  ...categoryMetadata
    .filter((category) => category.showInNavigation)
    .sort((a, b) => a.order - b.order)
    .map((category) => ({
      label: category.navigationLabel,
      href: `/category/${category.slug}`,
    })),
  { label: "About", href: "/about" },
];
---

<nav id={id} class="primary-nav" aria-label={ariaLabel}>
  <ul class="primary-nav__list" role="list">
    {navLinks.map((link) => (
      <li class="primary-nav__item">
        <a class="primary-nav__link" href={link.href}>
          {link.label}
        </a>
      </li>
    ))}
  </ul>
</nav>

<style>
  /* -------------------------------------------------------------------------
     Primary navigation — desktop
     Visibility is controlled by the parent (Header). This component styles
     the nav itself and lets the parent decide when to show/hide it.
     ------------------------------------------------------------------------- */
  .primary-nav {
    display: block;
  }

.primary-nav__list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  align-items: center;
  gap: 1.25rem;
}

@media (min-width: 1024px) {
  .primary-nav__list {
    gap: 2rem;
  }
}

  .primary-nav__item {
    margin: 0;
  }

  .primary-nav__link {
    font-family: var(--font-ui);
    font-size: var(--text-label);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text);
    text-decoration: none;
    padding-block: 0.5rem;
    transition: color var(--duration-base) var(--ease-quiet);
  }

  .primary-nav__link:hover,
  .primary-nav__link:focus-visible {
    color: var(--color-accent);
  }
</style>
