---
interface Props {
  children: any;
}

const { children } = Astro.props;
---

<article class="article-content">
  <slot />
</article>

<style>
  /* ----------------------------------------------------------
   * Editorial article body
   *
   * Owns only the reading measure and typography.
   * Images, affiliate boxes, pull quotes, etc.
   * become reusable child components later.
   * ---------------------------------------------------------- */

 .article-content {
  width: 100%;
  max-width: var(--container-reading);
  margin-inline: auto;

  padding-inline: var(--spacing-gutter);
  padding-block: calc(var(--spacing) * 12);
}

@media (min-width:1024px){
  .article-content{
    padding-inline: var(--spacing-gutter-lg);
  }
}

  .article-content :global(h2) {
    margin-top: calc(var(--spacing) * 14);
    margin-bottom: calc(var(--spacing) * 5);

    font-family: var(--font-display);
    font-size: var(--text-h2);
    line-height: 1.2;
    color: var(--color-text);
  }

  .article-content :global(h3) {
    margin-top: calc(var(--spacing) * 10);
    margin-bottom: calc(var(--spacing) * 4);

    font-family: var(--font-display);
    font-size: var(--text-h3);
    line-height: 1.3;
    color: var(--color-text);
  }

  .article-content :global(p) {
    margin: 0 0 calc(var(--spacing) * 6);

    font-family: var(--font-body);
    font-size: var(--text-body);
    line-height: 1.9;
    color: var(--color-text);
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    margin-bottom: calc(var(--spacing) * 6);
    padding-left: 1.5rem;
  }

  .article-content :global(li) {
    margin-bottom: 0.75rem;

    font-family: var(--font-body);
    line-height: 1.8;
  }

  .article-content :global(strong) {
    font-weight: 600;
  }

  .article-content :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .article-content :global(blockquote) {
    margin: calc(var(--spacing) * 12) 0;
    padding-left: 1.5rem;

    border-left: 3px solid var(--color-accent);

    font-family: var(--font-display);
    font-size: var(--text-h4);
    line-height: 1.5;
    font-style: italic;
    color: var(--color-text);
  }
</style>