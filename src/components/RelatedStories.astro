---
import StoryCard from "./StoryCard.astro";
import SectionHeading from "./SectionHeading.astro";

import type { Story } from "../lib/articles";
import { getRelatedStories } from "../lib/articles";

interface Props {
  currentStory: Story;
  stories: Story[];
}

const { currentStory, stories } = Astro.props;

const relatedStories = getRelatedStories(currentStory, stories);
const hasRelatedStories = relatedStories.length > 0;
---

{hasRelatedStories && (
  <section class="related-stories">
    <div class="site-container">

      <SectionHeading
        eyebrow="Continue Reading"
        title="You May Also Enjoy"
        description="More thoughtfully curated stories from The Wisteria Moonlight."
      />

      <ul class="related-grid" role="list">
        {relatedStories.map((story) => (
          <li class="related-grid__item">
            <StoryCard story={story} />
          </li>
        ))}
      </ul>

    </div>
  </section>
)}

<style>
  .related-stories {
    padding-block: var(--spacing-section);
  }

  .related-stories .site-container {
    max-width: var(--container-content);
    display: flex;
    flex-direction: column;
    gap: calc(var(--spacing) * 12);
  }

  .related-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: calc(var(--spacing) * 10);
  }

  .related-grid__item {
    margin: 0;
    display: flex;
  }

  @media (min-width: 768px) {
    .related-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (min-width: 1024px) {
    .related-stories {
      padding-block: var(--spacing-section-lg);
    }

    .related-stories .site-container {
      gap: calc(var(--spacing) * 16);
    }
  }
</style>
