---
/**
 * BaseLayout.astro
 * -----------------------------------------------------------------------------
 * The Wisteria Moonlight — foundational document layout.
 *
 * Provides the HTML document shell, essential document-level meta tags,
 * Google Fonts (Playfair Display, Lora, Inter), the global stylesheet,
 * and a single <slot /> for page content.
 *
 * Ownership boundaries:
 *   - BaseLayout owns document-level concerns:
 *       <title>, charset, viewport, theme-color, generator, favicon,
 *       fonts, global stylesheet, <slot />.
 *     <title> stays here because it is a required, always-present part
 *     of the HTML document shell — every page needs one, and BaseLayout
 *     is the single place that guarantees it.
 *
 *   - SEO.astro owns per-page metadata:
 *       <meta name="description">, <link rel="canonical">, Open Graph,
 *       and Twitter Card tags. These vary per page and are grouped in
 *       one reusable component so pages don't have to hand-wire them.
 *
 * Header, Footer, and Analytics are intentionally NOT included here.
 * -----------------------------------------------------------------------------
 */

import "../styles/global.css";
import SEO from "../components/SEO.astro";
import StructuredData from "../components/StructuredData.astro";
import type { JsonLd } from "../components/StructuredData.astro";
import { SITE, absoluteUrl } from "../data/siteMetadata";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
  type?: "website" | "article";
  schema?: JsonLd | JsonLd[];
}

const {
  title = "The Wisteria Moonlight | Dreamy Finds for a Softer Everyday",
  description = SITE.description,
  canonical,
  image,
  type = "website",
  schema,
} = Astro.props;

const baseSchema: JsonLd[] = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: SITE.name,
    url: SITE.url,
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: SITE.name,
    url: SITE.url,
    description: SITE.description,
    inLanguage: SITE.language,
    publisher: {
      "@type": "Organization",
      name: SITE.name,
      url: SITE.url,
    },
    potentialAction: {
      "@type": "ReadAction",
      target: absoluteUrl("/"),
    },
  },
];

const pageSchema = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#F7F3EC" />
    <meta name="generator" content={Astro.generator} />

    <!--
      BaseLayout owns <title> — it is part of the document shell and must
      always exist, regardless of whether a page provides SEO metadata.
    -->
    <title>{title}</title>

    <!--
      SEO owns per-page metadata: description, canonical, Open Graph,
      and Twitter Card tags. Keeping these in one reusable component
      ensures every page stays consistent without hand-wiring meta tags.
    -->
    <SEO
      title={title}
      description={description}
      canonical={canonical}
      image={image}
      type={type}
    />
    <StructuredData data={[...baseSchema, ...pageSchema]} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title={`${SITE.name} RSS`} href={absoluteUrl(SITE.rssPath)} />

<!-- Google Fonts: Playfair Display (display), Lora (body), Inter (UI) -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  rel="stylesheet"
  href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Lora:ital,wght@0,400..700;1,400..700&family=Inter:wght@400;500;600&display=swap"
/>
</head>
  <body>
    <slot />
  </body>
</html>
