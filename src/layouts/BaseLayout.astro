---
/**
 * BaseLayout.astro
 * -----------------------------------------------------------------------------
 * The Wisteria Moonlight — foundational document layout.
 *
 * Provides the HTML document shell, essential meta tags, Google Fonts
 * (Playfair Display, Lora, Inter), the global stylesheet, and a single
 * <slot /> for page content. Header, Footer, SEO, Analytics, and OG tags
 * are intentionally NOT included at this stage.
 * -----------------------------------------------------------------------------
 */

import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "The Wisteria Moonlight | Dreamy Finds for a Softer Everyday",
  description = "An editorial lifestyle publication — calm, elegant, and timeless.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#F7F3EC" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- Google Fonts: Playfair Display (display), Lora (body), Inter (UI) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Lora:ital,wght@0,400..700;1,400..700&family=Inter:wght@400;500;600&display=swap"
    />
  </head>
  <body>
    <slot />
  </body>
</html>