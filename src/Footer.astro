---
/**
 * Footer.astro
 * -----------------------------------------------------------------------------
 * The Wisteria Moonlight — Global site footer.
 *
 * Simple editorial footer with:
 *   • Brand and publication description
 *   • Primary navigation
 *   • Copyright row
 *
 * Uses design system tokens from global.css.
 * -----------------------------------------------------------------------------
 */

const navLinks = [
  { label: "Home", href: "/" },
  { label: "Home Finds", href: "/category/home-finds" },
  { label: "Beauty", href: "/category/beauty" },
  { label: "Travel", href: "/category/travel" },
  { label: "Gift Guides", href: "/category/gift-guides" },
  { label: "About", href: "/about" },
];
---

<footer class="site-footer">
  <div class="site-footer__container site-container">

    <div class="site-footer__content">
      <div class="site-footer__brand-block">
        <h2 class="site-footer__brand">
          The Wisteria Moonlight
        </h2>

        <p class="site-footer__description">
          A quiet editorial destination celebrating thoughtful living,
          timeless style, beautiful homes, meaningful gifts, and slow moments.
        </p>
      </div>

      <nav class="site-footer__nav" aria-label="Footer">
        <ul class="site-footer__nav-list" role="list">
          {navLinks.map((link) => (
  <li class="site-footer__nav-item">
    <a
      class="site-footer__nav-link"
      href={link.href}
    >
      {link.label}
    </a>
  </li>
))}
        </ul>
      </nav>
    </div>

    <div class="site-footer__bottom">
      <p class="site-footer__copyright">
        © 2026 The Wisteria Moonlight
      </p>
    </div>

  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border-soft);
    background-color: var(--color-surface);
  }

  .site-footer__container {
    padding-block: var(--spacing-section);
  }

  .site-footer__content {
    display: grid;
    gap: 2rem;
  }

  .site-footer__brand-block {
    max-width: var(--container-reading);
  }

  .site-footer__brand {
    margin: 0 0 1rem;
    font-family: var(--font-display);
    font-size: var(--text-h3);
    line-height: var(--text-h3--line-height);
    color: var(--color-text);
  }

  .site-footer__description {
    margin: 0;
    color: var(--color-text-muted);
  }

  .site-footer__nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.75rem;
  }

  .site-footer__nav-item {
    margin: 0;
  }

  .site-footer__nav-link {
    font-family: var(--font-ui);
    font-size: var(--text-label);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text);
    text-decoration: none;
    transition: color var(--duration-base) var(--ease-quiet);
  }

  .site-footer__nav-link:hover,
  .site-footer__nav-link:focus-visible {
    color: var(--color-accent);
  }

  .site-footer__bottom {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border-soft);
  }

  .site-footer__copyright {
    margin: 0;
    font-family: var(--font-ui);
    font-size: var(--text-label);
    color: var(--color-text-muted);
  }

  @media (min-width: 768px) {
    .site-footer__content {
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: start;
      gap: 4rem;
    }

    .site-footer__nav-list {
      justify-items: end;
    }
  }

  @media (min-width: 1024px) {
    .site-footer__container {
      padding-block: var(--spacing-section-lg);
    }
  }
</style>