---
/**
 * category/[slug].astro
 * ---------------------------------------------------------
 * Dynamic category listing page for The Wisteria Moonlight.
 *
 * Data sources (per the metadata refactor):
 *   - `categoryMetadata` (src/data/categoryMetadata.ts) is the
 *     single source of truth for a category's editorial identity
 *     (title, description, ordering, etc). This page never
 *     invents or duplicates that copy.
 *   - The `articles` Content Collection is the single source of
 *     truth for which articles belong to a category. Membership
 *     is resolved by slugifying `article.data.category` and
 *     comparing it against the route's `slug` param.
 *
 * Layout mirrors the rest of the site: Header, CategoryHeader,
 * a "Latest Stories" section (SectionHeading + StoryCard grid,
 * or an editorial empty state), Newsletter, Footer.
 *
 * Editorial rhythm: CategoryHeader introduces the category itself,
 * then a deliberately larger section-level gap separates it from
 * the "Latest Stories" listing below — the same section-rhythm
 * tokens used elsewhere on the site for major content breaks, not
 * the tighter gap used between elements within a single block.
 * This is intended as the reusable pattern for future landing
 * pages (e.g. tag pages, author pages).
 */

import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Newsletter from "../../components/Newsletter.astro";
import CategoryHeader from "../../components/CategoryHeader.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import StoryCard from "../../components/StoryCard.astro";

import { mapArticlesToStories, slugifyCategory } from "../../lib/articles";
import categoryMetadata from "../../data/categoryMetadata";

/**
 * getStaticPaths()
 * ---------------------------------------------------------
 * `categoryMetadata` is the source of truth for which categories
 * exist, so routes are derived from it directly (one static page
 * per entry) rather than from whatever categories happen to show
 * up in the article collection.
 */
export async function getStaticPaths() {
  return categoryMetadata.map((category) => ({
    params: { slug: category.slug },
  }));
}

/**
 * Resolve the current category
 * ---------------------------------------------------------
 * Look up the editorial metadata for this route's slug. A slug
 * with no matching entry means the route shouldn't exist — throw
 * rather than rendering a page with fabricated copy.
 */
const category = categoryMetadata.find(
  (entry) => entry.slug === Astro.params.slug
);

if (!category) {
  throw new Error(`No category metadata found for slug "${Astro.params.slug}"`);
}

/**
 * Matching articles
 * ---------------------------------------------------------
 * Filter the `articles` collection down to entries whose category
 * slugifies to this route's slug, then reuse the shared mapper —
 * never hand-roll the collection-entry -> Story transform here.
 */
const allArticles = await getCollection("articles");

const matchingArticles: CollectionEntry<"articles">[] = allArticles.filter(
  (article) => slugifyCategory(article.data.category) === category.slug
);

const stories = mapArticlesToStories(matchingArticles);

// Derived from the filtered list above so it can never drift out
// of sync with the grid rendered below it.
const articleCount = stories.length;
---
{/*
  Category SEO
  ---------------------------------------------------------
  categoryMetadata is the single source of truth for the
  category's editorial identity. The same metadata now
  drives both page content and SEO metadata so they can
  never drift out of sync.
*/}

<BaseLayout
  title={category.title}
  description={category.description}
  canonical={`/category/${category.slug}`}
  type="website"
>


  <Header />

  <main>
    <section class="category-page">
      <div class="category-page__container">

        <CategoryHeader
          eyebrow="Category"
          title={category.title}
          description={category.description}
          articleCount={articleCount}
        />

        <div class="category-page__stories">
          <SectionHeading title="Latest Stories" level="h2" align="left" />

          {stories.length > 0 ? (
            <ul class="category-page__grid" role="list">
              {stories.map((story) => (
                <li class="category-page__item">
                  <StoryCard story={story} />
                </li>
              ))}
            </ul>
          ) : (
            <div class="category-page__empty">
              <p class="category-page__empty-line">
                We're thoughtfully curating stories for this collection.
              </p>
              <p class="category-page__empty-line">
                Return soon for fresh inspiration.
              </p>
            </div>
          )}
        </div>

      </div>
    </section>

    <Newsletter
      eyebrow="Stay Connected"
      title="A Softer Inbox"
      description="Receive thoughtful recommendations, seasonal inspiration and beautifully curated finds."
    />
  </main>

  <Footer />
</BaseLayout>

<style>
  /* -----------------------------------------------------------------------
   * Section shell
   * Mirrors the vertical rhythm used by LatestPosts / FeaturedStories so
   * category pages feel consistent with the rest of the site.
   * ----------------------------------------------------------------------- */
  .category-page {
    padding-block: var(--spacing-section);
  }

  @media (min-width: 1024px) {
    .category-page {
      padding-block: var(--spacing-section-lg);
    }
  }

  /* -----------------------------------------------------------------------
   * Container
   * Same content measure and gutter as the rest of the site.
   * ----------------------------------------------------------------------- */
  .category-page__container {
    width: 100%;
    max-width: var(--container-content);
    margin-inline: auto;
    padding-inline: var(--spacing-gutter);

    display: flex;
    flex-direction: column;
  }

  @media (min-width: 1024px) {
    .category-page__container {
      padding-inline: var(--spacing-gutter-lg);
    }
  }

  /* -----------------------------------------------------------------------
   * Stories block
   * Groups the "Latest Stories" heading with the grid/empty state as
   * one editorial unit, and owns the gap *above itself* — i.e. the
   * separation from CategoryHeader. That gap intentionally uses the
   * section-rhythm tokens (--spacing-section*) rather than the
   * container's tighter internal gap, so CategoryHeader reads as its
   * own block and "Latest Stories" reads as a new section starting,
   * not just another stacked element. Internally it uses the same
   * tighter rhythm as SectionHeading-led sections elsewhere (e.g.
   * CategoryGrid) between the heading and its content.
   * ----------------------------------------------------------------------- */
  .category-page__stories {
    margin-block-start: var(--spacing-section);

    display: flex;
    flex-direction: column;
    gap: calc(var(--spacing) * 12);
  }

  @media (min-width: 1024px) {
    .category-page__stories {
      margin-block-start: var(--spacing-section-lg);
      gap: calc(var(--spacing) * 16);
    }
  }

  /* -----------------------------------------------------------------------
   * Grid
   * Same responsive column pattern as LatestPosts: 1 -> 2 -> 3 columns.
   * ----------------------------------------------------------------------- */
  .category-page__grid {
    list-style: none;
    margin: 0;
    padding: 0;

    display: grid;
    grid-template-columns: 1fr;
    gap: calc(var(--spacing) * 10);
  }

  @media (min-width: 640px) {
    .category-page__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1024px) {
    .category-page__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: calc(var(--spacing) * 12);
    }
  }

  .category-page__item {
    margin: 0;
    display: flex;
  }

  /* -----------------------------------------------------------------------
   * Empty state
   * Editorial placeholder for a category with no matching articles
   * yet — reads like a quiet note from the editors rather than a
   * technical "no results" message. Centered, muted, no illustration,
   * generous breathing room so it doesn't feel like an error state.
   * ----------------------------------------------------------------------- */
  .category-page__empty {
    max-width: 32rem;
    margin-inline: auto;
    padding-block: calc(var(--spacing) * 8);

    display: flex;
    flex-direction: column;
    gap: calc(var(--spacing) * 2);

    text-align: center;
  }

  .category-page__empty-line {
    margin: 0;
    font-family: var(--font-body);
    font-style: italic;
    font-size: var(--text-body);
    line-height: var(--text-body--line-height);
    color: var(--color-text-muted);
    text-wrap: pretty;
  }
</style>