---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
---

<BaseLayout>
  <Header />

  <main>
    <Hero />

    <section class="homepage-placeholder site-container section">
      <div class="reading-width">
        <h2>More Beautiful Things Are Coming</h2>
        <p>
          This space will soon feature curated stories, seasonal inspiration,
          thoughtful recommendations, and editorial collections.
        </p>
      </div>
    </section>
  </main>
</BaseLayout>