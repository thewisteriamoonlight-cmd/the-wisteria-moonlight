---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Footer from "../components/Footer.astro";

import FeaturedStories from "../components/FeaturedStories.astro";
import CategoryGrid from "../components/CategoryGrid.astro";
import LatestPosts from "../components/LatestPosts.astro";
import Newsletter from "../components/Newsletter.astro";

import categoryMetadata from "../data/categoryMetadata";
import { getCollection } from "astro:content";
import { mapArticlesToStories, sortStoriesByDateDesc } from "../lib/articles";
import { SITE, absoluteUrl } from "../data/siteMetadata";
import homepageImage from "../assets/images/posts/cozy-living.jpg";

const articles = await getCollection("articles");

const posts = sortStoriesByDateDesc(mapArticlesToStories(articles));

// Homepage only shows categories flagged `showOnHomepage`, in
// their editorial `order`. Both flags live in the single source
// of truth (src/data/categoryMetadata.ts) — nothing category-
// specific is decided here.
const homepageCategories = categoryMetadata
  .filter((category) => category.showOnHomepage)
  .sort((a, b) => a.order - b.order);

const homepageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: SITE.name,
  description: SITE.description,
  url: absoluteUrl("/"),
  inLanguage: SITE.language,
  isPartOf: {
    "@type": "WebSite",
    name: SITE.name,
    url: SITE.url,
  },
};
---

<BaseLayout image={homepageImage.src} schema={homepageSchema}>
  <Header />

  <main>
    <Hero />

    <FeaturedStories
      eyebrow="Editor's Picks"
      title="Featured Stories"
      description="A curated selection of timeless articles chosen to inspire slower, softer everyday living."
      stories={posts.filter((post) => post.featured)}
    />

    <CategoryGrid
      eyebrow="Browse"
      title="Explore by Category"
      description="Discover thoughtfully curated collections for every corner of life."
      categories={homepageCategories}
    />

    <LatestPosts
      eyebrow="Recently Published"
      title="Latest Posts"
      description="Fresh editorial stories, beautiful discoveries and seasonal inspiration."
      posts={posts}
    />

    <Newsletter
      eyebrow="Stay Connected"
      title="A Softer Inbox"
      description="Receive thoughtful recommendations, seasonal inspiration and beautifully curated finds."
    />
  </main>

  <Footer />
</BaseLayout>
