---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Footer from "../components/Footer.astro";

import FeaturedStories from "../components/FeaturedStories.astro";
import CategoryGrid from "../components/CategoryGrid.astro";
import LatestPosts from "../components/LatestPosts.astro";
import Newsletter from "../components/Newsletter.astro";

import categories from "../data/categories";
import { getCollection } from "astro:content";
import { mapArticlesToStories, sortStoriesByDateDesc } from "../lib/articles";

const articles = await getCollection("articles");

const posts = sortStoriesByDateDesc(mapArticlesToStories(articles));
---

<BaseLayout>
  <Header />

  <main>
    <Hero />

    <FeaturedStories
      eyebrow="Editor's Picks"
      title="Featured Stories"
      description="A curated selection of timeless articles chosen to inspire slower, softer everyday living."
      stories={posts.filter((post) => post.featured)}
    />

    <CategoryGrid
      eyebrow="Browse"
      title="Explore by Category"
      description="Discover thoughtfully curated collections for every corner of life."
      categories={categories}
    />

    <LatestPosts
      eyebrow="Recently Published"
      title="Latest Posts"
      description="Fresh editorial stories, beautiful discoveries and seasonal inspiration."
      posts={posts}
    />

    <Newsletter
      eyebrow="Stay Connected"
      title="A Softer Inbox"
      description="Receive thoughtful recommendations, seasonal inspiration and beautifully curated finds."
    />
  </main>xml

  <Footer />
</BaseLayout>