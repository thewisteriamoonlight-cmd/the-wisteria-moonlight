---
/**
 * journal/[slug].astro
 * ---------------------------------------------------------
 * Editorial article page for The Wisteria Moonlight.
 *
 * Sources content from the `articles` Astro Content
 * Collection. The layout — Header, ArticleHeader,
 * ArticleContent, RelatedStories, Newsletter, Footer — is
 * unchanged.
 */

import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";

import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Newsletter from "../../components/Newsletter.astro";

import ArticleHeader from "../../components/ArticleHeader.astro";
import ArticleContent from "../../components/ArticleContent.astro";
import RelatedStories from "../../components/RelatedStories.astro";

import { mapArticlesToStories } from "../../lib/articles";

export async function getStaticPaths() {
  const articles = await getCollection("articles");

  return articles.map((article) => ({
    params: {
      slug: article.id,
    },
    props: {
      article,
    },
  }));
}

interface Props {
  article: CollectionEntry<"articles">;
}

const { article } = Astro.props;

// Render the Markdown body of this article as a component.
const { Content } = await render(article);

// RelatedStories consumes the shared `Story` shape (see
// src/lib/articles.ts) rather than raw collection entries.
const allArticles = await getCollection("articles");
const stories = mapArticlesToStories(allArticles);

// The schema stores `date` as a Date (via z.coerce.date()).
// ArticleHeader expects an ISO date string, so we convert here.
const formattedDate = article.data.date.toISOString().split("T")[0];
---

<BaseLayout
  title={article.data.title}
  description={article.data.excerpt}
>
  <Header />

  <main>

    <ArticleHeader
      category={article.data.category}
      title={article.data.title}
      date={formattedDate}
      readTime={article.data.readTime}
      image={article.data.heroImage}
      imageAlt={article.data.heroImageAlt}
    />

    <ArticleContent>
      <Content />
    </ArticleContent>

    <RelatedStories
      currentSlug={article.id}
      stories={stories}
    />

  </main>

  <Newsletter
    eyebrow="Stay Connected"
    title="A Softer Inbox"
    description="Receive thoughtful recommendations, seasonal inspiration and beautifully curated finds."
  />

  <Footer />

</BaseLayout>