---
/**
 * journal/[slug].astro
 * ---------------------------------------------------------
 * Editorial article page for The Wisteria Moonlight.
 *
 * Now sources content from the `articles` Astro Content
 * Collection (replacing the previous src/data/posts.ts).
 * The layout — Header, ArticleHeader, ArticleContent,
 * RelatedStories, Newsletter, Footer — is unchanged.
 */

import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";

import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Newsletter from "../../components/Newsletter.astro";

import ArticleHeader from "../../components/ArticleHeader.astro";
import ArticleContent from "../../components/ArticleContent.astro";
import RelatedStories from "../../components/RelatedStories.astro";

export async function getStaticPaths() {
  const articles = await getCollection("articles");

  return articles.map((article) => ({
    params: {
      slug: article.id,
    },
    props: {
      article,
    },
  }));
}

interface Props {
  article: CollectionEntry<"articles">;
}

const { article } = Astro.props;

// Render the Markdown body of this article as a component.
const { Content } = await render(article);

// RelatedStories still consumes the legacy posts.ts data shape.
// We preserve its public API by mapping every collection entry into
// that same shape here, so no downstream component changes are needed.
const allArticles = await getCollection("articles");

const stories = allArticles.map((entry) => ({
  title: entry.data.title,
  slug: entry.id,
  href: `/journal/${entry.id}`,
  image: entry.data.heroImage,
  imageAlt: entry.data.heroImageAlt,
  category: entry.data.category,
  excerpt: entry.data.excerpt,
  date: entry.data.date.toISOString().split("T")[0],
  featured: entry.data.featured,
}));

// The schema stores `date` as a Date (via z.coerce.date()).
// ArticleHeader previously received an ISO date string from posts.ts,
// so we convert here to keep its API identical.
const formattedDate = article.data.date.toISOString().split("T")[0];
---

<BaseLayout
  title={article.data.title}
  description={article.data.excerpt}
>
  <Header />

  <main>

    <ArticleHeader
      category={article.data.category}
      title={article.data.title}
      date={formattedDate}
      readTime={article.data.readTime}
      image={article.data.heroImage}
      imageAlt={article.data.heroImageAlt}
    />

    <ArticleContent>
      <Content />
    </ArticleContent>

    <RelatedStories
      currentSlug={article.id}
      stories={stories}
    />

  </main>

  <Newsletter
    eyebrow="Stay Connected"
    title="A Softer Inbox"
    description="Receive thoughtful recommendations, seasonal inspiration and beautifully curated finds."
  />

  <Footer />

</BaseLayout>