---
/**
 * journal/[slug].astro
 * ---------------------------------------------------------
 * Editorial article page for The Wisteria Moonlight.
 *
 * Sources content from the `articles` Astro Content
 * Collection. The layout — Header, ArticleHeader,
 * ArticleContent, RelatedStories, Newsletter, Footer — is
 * unchanged.
 */

import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";

import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Newsletter from "../../components/Newsletter.astro";

import ArticleHeader from "../../components/ArticleHeader.astro";
import ArticleContent from "../../components/ArticleContent.astro";
import RelatedStories from "../../components/RelatedStories.astro";

import {
  mapArticleToStory,
  mapArticlesToStories,
  slugifyCategory,
} from "../../lib/articles";
import { SITE, absoluteUrl } from "../../data/siteMetadata";

export async function getStaticPaths() {
  const articles = await getCollection("articles");

  return articles.map((article) => ({
    params: {
      slug: article.id,
    },
    props: {
      article,
    },
  }));
}

interface Props {
  article: CollectionEntry<"articles">;
}

const { article } = Astro.props;

// Render the Markdown body of this article as a component.
const { Content } = await render(article);

// RelatedStories consumes the shared `Story` shape (see
// src/lib/articles.ts) rather than raw collection entries.
const allArticles = await getCollection("articles");
const stories = mapArticlesToStories(allArticles);
const currentStory = mapArticleToStory(article);

// The schema stores `date` as a Date (via z.coerce.date()).
// ArticleHeader expects an ISO date string, so we convert here.
const formattedDate = article.data.date.toISOString().split("T")[0];
const formattedUpdatedDate =
  article.data.updatedDate?.toISOString().split("T")[0] ?? formattedDate;
const author = article.data.author ?? SITE.defaultAuthor;
const articleUrl = `/journal/${article.id}`;
const imageUrl = absoluteUrl(article.data.heroImage.src);

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: article.data.title,
  description: article.data.excerpt,
  image: imageUrl,
  datePublished: article.data.date.toISOString(),
  dateModified: article.data.updatedDate?.toISOString() ?? article.data.date.toISOString(),
  author: {
    "@type": "Person",
    name: author,
  },
  publisher: {
    "@type": "Organization",
    name: SITE.name,
    url: SITE.url,
  },
  mainEntityOfPage: absoluteUrl(articleUrl),
  articleSection: article.data.category,
  keywords: article.data.tags,
  inLanguage: SITE.language,
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: absoluteUrl("/"),
    },
    {
      "@type": "ListItem",
      position: 2,
      name: article.data.category,
      item: absoluteUrl(`/category/${slugifyCategory(article.data.category)}`),
    },
    {
      "@type": "ListItem",
      position: 3,
      name: article.data.title,
      item: absoluteUrl(articleUrl),
    },
  ],
};
---

{/*
  Phase 4.3
  ---------------------------------------------------------
  Supply article-specific SEO data to BaseLayout.

  BaseLayout forwards these props to the shared SEO component.
  The page never renders meta tags directly.

  - canonical: generated from the article's id so the tag
    always stays in sync with the route — never hardcoded.
  - image: the hero image's resolved `src` string (Astro's
    image() helper returns an ImageMetadata object; SEO expects
    a string path so it can resolve against Astro.site).
  - type: "article" for Open Graph article semantics.
*/}
<BaseLayout
  title={article.data.title}
  description={article.data.excerpt}
  canonical={articleUrl}
  image={article.data.heroImage.src}
  type="article"
  schema={[articleSchema, breadcrumbSchema]}
>
  <Header />

  <main>

    <ArticleHeader
      category={article.data.category}
      title={article.data.title}
      date={formattedDate}
      readTime={article.data.readTime}
      author={author}
      updatedDate={formattedUpdatedDate !== formattedDate ? formattedUpdatedDate : undefined}
      image={article.data.heroImage}
      imageAlt={article.data.heroImageAlt}
    />

    <ArticleContent>
      <Content />
    </ArticleContent>

    <RelatedStories
      currentStory={currentStory}
      stories={stories}
    />

  </main>

  <Newsletter
    eyebrow="Stay Connected"
    title="A Softer Inbox"
    description="Receive thoughtful recommendations, seasonal inspiration and beautifully curated finds."
  />

  <Footer />

</BaseLayout>
